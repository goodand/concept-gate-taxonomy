    OUT["return<br/>hierarchy + stereotypes + unsatisfiable<br/>+ equivalence_groups + has_nontrivial_equivalences<br/>(+ representatives optional)"]

    START --> PASS0 --> PASS1 --> PASS2 --> OUT
